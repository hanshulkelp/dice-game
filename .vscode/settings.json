        "/^python3 - << 'PYEOF'\ncss = r\"\"\"/\\* ══════════════════════════════════════════\n   LEADERBOARD – complete stylesheet\n══════════════════════════════════════════ \\*/\n\n/\\* ── page wrapper / CSS variables ── \\*/\n\\.lb-page \\{\n  --gold:       #d4a017;\n  --gold-light: #f0c040;\n  --gold-glow:  rgba\\(212,160,23,0\\.35\\);\n  --silver:     #a0aec0;\n  --bronze:     #cd7f32;\n  --bg-deep:    #0b0d1a;\n  --bg-card:    #12152b;\n  --bg-row:     #0e1020;\n  --bg-row-alt: #12152b;\n  --border:     rgba\\(255,255,255,0\\.07\\);\n  --text-main:  #e8eaf6;\n  --text-muted: #6b7aaa;\n  --radius:     14px;\n\n  min-height: 100vh;\n  background: radial-gradient\\(ellipse at 50% 0%, #1b1148 0%, #0b0d1a 65%\\);\n  color: var\\(--text-main\\);\n  font-family: \"Inter\", \"Segoe UI\", sans-serif;\n  padding: 3\\.5rem 1\\.5rem 5rem;\n  box-sizing: border-box;\n\\}\n\n/\\* ══ HEADER ══════════════════════════════ \\*/\n\n\\.lb-header \\{\n  text-align: center;\n  margin-bottom: 3rem;\n\\}\n\n\\.trophy-icon \\{\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  width: 62px;\n  height: 62px;\n  background: rgba\\(212,160,23,0\\.12\\);\n  border-radius: 50%;\n  margin-bottom: 1\\.1rem;\n  color: var\\(--gold-light\\);\n\\}\n\\.trophy-icon svg \\{ width: 34px; height: 34px; \\}\n\n\\.lb-title \\{\n  font-size: clamp\\(2rem, 5vw, 3\\.2rem\\);\n  font-weight: 900;\n  letter-spacing: 0\\.22em;\n  background: linear-gradient\\(135deg, var\\(--gold-light\\) 0%, var\\(--gold\\) 55%, #a06b00 100%\\);\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n  background-clip: text;\n  margin: 0 0 0\\.65rem;\n\\}\n\n\\.lb-subtitle \\{\n  color: var\\(--text-muted\\);\n  font-size: 0\\.93rem;\n  line-height: 1\\.7;\n  margin: 0;\n\\}\n\n/\\* ══ PODIUM ══════════════════════════════ \\*/\n\n\\.podium-section \\{\n  max-width: 820px;\n  margin: 0 auto 4rem;\n\\}\n\n\\.podium-wrapper \\{\n  display: flex;\n  align-items: flex-end;\n  justify-content: center;\n  gap: 1\\.5rem;\n\\}\n\n/\\* Each card column \\*/\n\\.podium-card \\{\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n\\}\n\n/\\* ordering & elevation \\*/\n\\.rank-1 \\{ order: 2; transform: translateY\\(-48px\\); \\}\n\\.rank-2 \\{ order: 1; \\}\n\\.rank-3 \\{ order: 3; \\}\n\n/\\* ── Avatar ring ── \\*/\n\\.avatar-wrap \\{\n  position: relative;\n  border-radius: 50%;\n  padding: 3px;\n  margin-bottom: 0\\.9rem;\n\\}\n\\.avatar-wrap img \\{\n  display: block;\n  border-radius: 50%;\n  object-fit: cover;\n  background: var\\(--bg-card\\);\n\\}\n\n\\.avatar-1 \\{\n  width: 100px; height: 100px;\n  background: linear-gradient\\(135deg, var\\(--gold-light\\), var\\(--gold\\)\\);\n  box-shadow: 0 0 28px var\\(--gold-glow\\);\n\\}\n\\.avatar-1 img \\{ width: 94px; height: 94px; \\}\n\n\\.avatar-2 \\{\n  width: 78px; height: 78px;\n  background: linear-gradient\\(135deg, #d0dce8, var\\(--silver\\)\\);\n\\}\n\\.avatar-2 img \\{ width: 72px; height: 72px; \\}\n\n\\.avatar-3 \\{\n  width: 78px; height: 78px;\n  background: linear-gradient\\(135deg, #e8a060, var\\(--bronze\\)\\);\n\\}\n\\.avatar-3 img \\{ width: 72px; height: 72px; \\}\n\n/\\* ── Rank badge ── \\*/\n\\.rank-badge \\{\n  position: absolute;\n  bottom: -3px;\n  right: -3px;\n  width: 24px; height: 24px;\n  border-radius: 50%;\n  display: flex; align-items: center; justify-content: center;\n  font-size: 0\\.72rem;\n  font-weight: 800;\n  color: #09090f;\n  border: 2px solid var\\(--bg-deep\\);\n\\}\n\\.rank-1 \\.rank-badge \\{\n  background: linear-gradient\\(135deg, var\\(--gold-light\\), var\\(--gold\\)\\);\n  width: 28px; height: 28px;\n  font-size: 0\\.82rem;\n\\}\n\\.rank-2 \\.rank-badge \\{ background: linear-gradient\\(135deg, #d0dce8, var\\(--silver\\)\\); \\}\n\\.rank-3 \\.rank-badge \\{ background: linear-gradient\\(135deg, #e8a060, var\\(--bronze\\)\\); \\}\n\n/\\* ── First-place centre card ── \\*/\n\\.first-card \\{\n  background: linear-gradient\\(160deg, #1c2044 0%, #131626 100%\\);\n  border: 1px solid rgba\\(212,160,23,0\\.28\\);\n  border-radius: var\\(--radius\\);\n  padding: 1\\.6rem 2\\.2rem 1\\.4rem;\n  text-align: center;\n  min-width: 230px;\n  box-shadow: 0 10px 36px rgba\\(0,0,0,0\\.55\\);\n\\}\n\n\\.rank-divider \\{\n  display: block;\n  width: 55%;\n  height: 2px;\n  background: linear-gradient\\(90deg, transparent, var\\(--gold\\), transparent\\);\n  margin: 0 auto 1rem;\n\\}\n\n\\.first-name \\{\n  font-size: 1\\.35rem;\n  font-weight: 700;\n  color: var\\(--text-main\\);\n  margin: 0 0 0\\.3rem;\n\\}\n\n\\.first-tag \\{\n  font-size: 0\\.7rem;\n  font-weight: 700;\n  letter-spacing: 0\\.14em;\n  color: var\\(--gold\\);\n  margin: 0 0 1\\.3rem;\n\\}\n\n\\.first-stats \\{\n  display: flex;\n  justify-content: center;\n  gap: 2\\.2rem;\n\\}\n\n\\.stat-block \\{\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 0\\.22rem;\n\\}\n\n\\.stat-value \\{\n  font-size: 1\\.5rem;\n  font-weight: 800;\n  color: var\\(--text-main\\);\n\\}\n\\.stat-value\\.gold \\{ color: var\\(--gold\\); \\}\n\n\\.stat-label \\{\n  font-size: 0\\.62rem;\n  letter-spacing: 0\\.11em;\n  color: var\\(--text-muted\\);\n\\}\n\n/\\* ── Side cards \\(rank 2 & 3\\) ── \\*/\n\\.side-card \\{\n  background: linear-gradient\\(160deg, #15182e 0%, #0f111e 100%\\);\n  border: 1px solid var\\(--border\\);\n  border-radius: var\\(--radius\\);\n  padding: 1\\.1rem 1\\.4rem 1rem;\n  text-align: center;\n  min-width: 175px;\n  box-shadow: 0 4px 22px rgba\\(0,0,0,0\\.45\\);\n\\}\n\n\\.side-name \\{\n  font-size: 1\\.05rem;\n  font-weight: 700;\n  margin: 0 0 0\\.22rem;\n  color: var\\(--text-main\\);\n\\}\n\n\\.side-title \\{\n  font-size: 0\\.75rem;\n  color: var\\(--text-muted\\);\n  margin: 0 0 0\\.95rem;\n\\}\n\n\\.side-stats \\{\n  display: flex;\n  justify-content: center;\n  gap: 1\\.5rem;\n\\}\n\n\\.stat-small \\{\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 0\\.15rem;\n\\}\n\n\\.stat-val-s \\{\n  font-size: 1\\.1rem;\n  font-weight: 800;\n  color: var\\(--text-main\\);\n\\}\n\\.stat-val-s\\.gold \\{ color: var\\(--gold\\); \\}\n\n\\.stat-lbl-s \\{\n  font-size: 0\\.6rem;\n  letter-spacing: 0\\.09em;\n  color: var\\(--text-muted\\);\n\\}\n\n/\\* ══ FULL RANKINGS ═══════════════════════ \\*/\n\n\\.rankings-section \\{\n  max-width: 900px;\n  margin: 0 auto;\n\\}\n\n\\.rankings-header \\{\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  margin-bottom: 1\\.3rem;\n  flex-wrap: wrap;\n  gap: 0\\.75rem;\n\\}\n\n\\.rankings-title \\{\n  display: flex;\n  align-items: center;\n  gap: 0\\.65rem;\n  font-size: 1\\.2rem;\n  font-weight: 700;\n  margin: 0;\n  color: var\\(--text-main\\);\n\\}\n\n\\.title-bar \\{\n  display: inline-block;\n  width: 4px;\n  height: 1\\.25em;\n  border-radius: 2px;\n  background: linear-gradient\\(180deg, var\\(--gold-light\\), var\\(--gold\\)\\);\n\\}\n\n\\.update-badge \\{\n  display: flex;\n  align-items: center;\n  gap: 0\\.4rem;\n  font-size: 0\\.75rem;\n  color: var\\(--text-muted\\);\n\\}\n\n/\\* ── Table ── \\*/\n\\.rankings-table \\{\n  border: 1px solid var\\(--border\\);\n  border-radius: var\\(--radius\\);\n  overflow: hidden;\n  background: var\\(--bg-card\\);\n\\}\n\n\\.table-head,\n\\.table-row \\{\n  display: grid;\n  grid-template-columns: 80px 1fr 130px 140px 200px;\n  align-items: center;\n  padding: 0 1\\.6rem;\n\\}\n\n\\.table-head \\{\n  padding-top: 0\\.85rem;\n  padding-bottom: 0\\.85rem;\n  border-bottom: 1px solid var\\(--border\\);\n  font-size: 0\\.67rem;\n  letter-spacing: 0\\.11em;\n  color: var\\(--text-muted\\);\n  text-transform: uppercase;\n\\}\n\n\\.table-row \\{\n  padding-top: 1\\.05rem;\n  padding-bottom: 1\\.05rem;\n  border-bottom: 1px solid var\\(--border\\);\n  transition: background 0\\.15s;\n  background: var\\(--bg-row\\);\n\\}\n\\.table-row:last-child \\{ border-bottom: none; \\}\n\\.table-row:hover \\{ background: rgba\\(255,255,255,0\\.035\\); \\}\n\\.row-odd \\{ background: var\\(--bg-row-alt\\); \\}\n\n/\\* ── Column cells ── \\*/\n\\.rank-num \\{\n  font-size: 1rem;\n  font-weight: 600;\n  color: var\\(--text-muted\\);\n\\}\n\n\\.player-info \\{\n  display: flex;\n  align-items: center;\n  gap: 0\\.8rem;\n\\}\n\n\\.row-avatar \\{\n  width: 40px; height: 40px;\n  border-radius: 50%;\n  object-fit: cover;\n  background: var\\(--bg-deep\\);\n  flex-shrink: 0;\n\\}\n\n\\.player-text \\{\n  display: flex;\n  flex-direction: column;\n  gap: 0\\.18rem;\n\\}\n\n\\.player-name \\{\n  font-size: 0\\.93rem;\n  font-weight: 600;\n  color: var\\(--text-main\\);\n\\}\n\n\\.player-tier \\{\n  font-size: 0\\.63rem;\n  letter-spacing: 0\\.09em;\n  color: var\\(--text-muted\\);\n\\}\n\n\\.stat-wins,\n\\.stat-games \\{\n  font-size: 0\\.95rem;\n  font-weight: 600;\n  color: var\\(--text-main\\);\n\\}\n\n/\\* ── Win-rate bar ── \\*/\n\\.rate-cell \\{\n  display: flex;\n  align-items: center;\n  gap: 0\\.65rem;\n\\}\n\n\\.rate-bar-track \\{\n  flex: 1;\n  height: 6px;\n  background: rgba\\(255,255,255,0\\.08\\);\n  border-radius: 3px;\n  overflow: hidden;\n\\}\n\n\\.rate-bar-fill \\{\n  height: 100%;\n  background: linear-gradient\\(90deg, var\\(--gold\\), var\\(--gold-light\\)\\);\n  border-radius: 3px;\n  transition: width 0\\.7s ease;\n\\}\n\n\\.rate-pct \\{\n  font-size: 0\\.8rem;\n  font-weight: 700;\n  color: var\\(--gold-light\\);\n  min-width: 36px;\n  text-align: right;\n\\}\n\n/\\* ── View More button ── \\*/\n\\.view-more-wrap \\{\n  display: flex;\n  justify-content: center;\n  margin-top: 2\\.8rem;\n\\}\n\n\\.view-more-btn \\{\n  display: inline-flex;\n  align-items: center;\n  gap: 0\\.5rem;\n  background: linear-gradient\\(135deg, var\\(--gold-light\\), var\\(--gold\\)\\);\n  color: #0a0900;\n  border: none;\n  border-radius: 50px;\n  padding: 0\\.78rem 2\\.2rem;\n  font-size: 0\\.9rem;\n  font-weight: 700;\n  letter-spacing: 0\\.04em;\n  cursor: pointer;\n  transition: transform 0\\.15s, box-shadow 0\\.15s;\n  box-shadow: 0 4px 22px var\\(--gold-glow\\);\n\\}\n\\.view-more-btn:hover \\{\n  transform: translateY\\(-2px\\);\n  box-shadow: 0 8px 30px var\\(--gold-glow\\);\n\\}\n\\.view-more-btn:active \\{ transform: translateY\\(0\\); \\}\n\n/\\* ══ RESPONSIVE ═════════════════════════ \\*/\n@media \\(max-width: 750px\\) \\{\n  \\.table-head,\n  \\.table-row \\{ grid-template-columns: 48px 1fr 90px 0px 130px; \\}\n  \\.col-games \\{ display: none; \\}\n  \\.rank-1 \\{ transform: translateY\\(-28px\\); \\}\n  \\.first-card \\{ min-width: 176px; padding: 1\\.1rem 1\\.2rem 1rem; \\}\n  \\.side-card  \\{ min-width: 136px; \\}\n\\}\n\n@media \\(max-width: 520px\\) \\{\n  \\.podium-wrapper \\{ gap: 0\\.7rem; \\}\n  \\.table-head,\n  \\.table-row \\{ grid-template-columns: 36px 1fr 70px 120px; \\}\n  \\.col-games \\{ display: none; \\}\n\\}\n\"\"\"\n\nwith open\\(\n  \"/Users/hanshul/Desktop/Projects/dice-game/apps/web/src/app/pages/leaderboard/leaderboard/leaderboard\\.component\\.css\",\n  \"w\"\n\\) as f:\n    f\\.write\\(css\\)\n\nimport os\nsize = os\\.path\\.getsize\\(\"/Users/hanshul/Desktop/Projects/dice-game/apps/web/src/app/pages/leaderboard/leaderboard/leaderboard\\.component\\.css\"\\)\nprint\\(f\"Written \\{size\\} bytes, \\{len\\(css\\.splitlines\\(\\)\\)\\} lines\"\\)\nPYEOF$/": {
