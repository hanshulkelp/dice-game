        "/^python3 - << 'PYEOF'\ncss = \"\"\"/\\* ══════════════════════════════════════════\n   GAME RESULT – complete stylesheet\n══════════════════════════════════════════ \\*/\n\n\\.gr-page \\{\n  --gold:       #d4a017;\n  --gold-light: #f0c040;\n  --gold-glow:  rgba\\(212,160,23,0\\.35\\);\n  --silver:     #a0aec0;\n  --bronze:     #cd7f32;\n  --bg:         #0d0f1e;\n  --bg-card:    #141829;\n  --bg-row:     #1a1d30;\n  --border:     rgba\\(255,255,255,0\\.07\\);\n  --text-main:  #e8eaf6;\n  --text-muted: #6b7aaa;\n  --radius:     16px;\n\n  min-height: 100vh;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  background: radial-gradient\\(ellipse at 50% 0%, #1b1148 0%, #0d0f1e 65%\\);\n  padding: 2rem 1rem;\n  box-sizing: border-box;\n  font-family: \"Inter\", \"Segoe UI\", sans-serif;\n  color: var\\(--text-main\\);\n\\}\n\n/\\* ── Card container ── \\*/\n\\.gr-card \\{\n  width: 100%;\n  max-width: 460px;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 0;\n\\}\n\n/\\* ══ TROPHY ══ \\*/\n\\.trophy-icon \\{\n  position: relative;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  width: 90px;\n  height: 90px;\n  border-radius: 50%;\n  margin-bottom: 1\\.5rem;\n\\}\n\n\\.trophy-icon\\.win \\{\n  background: radial-gradient\\(circle, rgba\\(212,160,23,0\\.22\\) 0%, transparent 70%\\);\n  color: var\\(--gold\\);\n\\}\n\n\\.trophy-icon\\.loss \\{\n  background: radial-gradient\\(circle, rgba\\(100,100,140,0\\.18\\) 0%, transparent 70%\\);\n  color: var\\(--text-muted\\);\n\\}\n\n\\.trophy-icon svg \\{\n  width: 56px;\n  height: 56px;\n\\}\n\n\\.crown \\{\n  position: absolute;\n  top: -10px;\n  left: 50%;\n  transform: translateX\\(-50%\\);\n  font-size: 1\\.5rem;\n  line-height: 1;\n\\}\n\n/\\* ══ TITLE ══ \\*/\n\\.result-title \\{\n  font-size: clamp\\(2rem, 8vw, 2\\.8rem\\);\n  font-weight: 900;\n  letter-spacing: 0\\.06em;\n  margin: 0 0 0\\.6rem;\n  text-align: center;\n\\}\n\n\\.result-